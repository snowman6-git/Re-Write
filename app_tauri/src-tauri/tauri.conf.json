{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReWrite",
  "version": "0.1.0",
  "identifier": "com.snowman6.rewrite",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build ../../frontend_svelte",
    "frontendDist": "../../frontend_svelte/build"
  },
  "app": {
    "windows": [
      {
        "title": "Re:Write",
        "width":  900,
        "height": 1950
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
